# ── Backend environment variables ────────────────────────────────────────
# Copy this file to .env and populate before running the backend.
# NEVER commit .env to source control.

# ── AWS ───────────────────────────────────────────────────────────────────
# AWS profile configured via ~/.aws/credentials or instance/task role.
# Leave blank when running on EC2/ECS with an attached IAM role.
AWS_PROFILE=loan-origination-dev
AWS_REGION=us-east-1

# ── Amazon Cognito (output by terraform apply) ───────────────────────────
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# JWKS URI is derived from pool ID — only override for local mocking.
# COGNITO_JWKS_URI=

# ── S3 Storage (output by terraform apply) ───────────────────────────────
S3_BUCKET_NAME=loan-origination-documents-demo
# Optional: use a local mock endpoint (e.g. LocalStack) during development.
# S3_ENDPOINT_URL=http://localhost:4566

# ── AgentCore Runtime (output by terraform apply) ────────────────────────
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock:us-east-1:123456789012:agent-runtime/XXXXXXXXXX
AGENTCORE_GATEWAY_ARN=arn:aws:bedrock:us-east-1:123456789012:agent-gateway/XXXXXXXXXX

# ── Application settings ─────────────────────────────────────────────────
APP_ENV=development
# Set to "local" to run LangGraph in-process instead of via AgentCore Runtime.
RUNTIME_MODE=local
LOG_LEVEL=INFO

# ── API Keys (never hard-code; always from env/SSM) ──────────────────────
# Llama Cloud API key for LlamaParse document processing (Phase 4).
# LLAMA_CLOUD_API_KEY=llx-...
