.python-version

# ── Node / Frontend ──────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.vite/
.npm/

# ── Terraform ────────────────────────────────────────────────────────────
.terraform/
# .terraform.lock.hcl is intentionally committed for reproducible provider pins
*.tfstate
*.tfstate.backup
*.tfstate.d/
*.tfplan
*.tfvars
# Keep examples committed
!*.tfvars.example

# ── Environment / Secrets ────────────────────────────────────────────────
.env
.env.local
.env.*.local
# Keep examples committed
!.env.example

# ── AWS ──────────────────────────────────────────────────────────────────
.aws/credentials
*.pem
*.p12
*.pfx

# ── IDE / OS ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Misc ─────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
# .secrets.baseline is intentionally committed so detect-secrets can diff against it
