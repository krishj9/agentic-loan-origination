# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
*.egg
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
