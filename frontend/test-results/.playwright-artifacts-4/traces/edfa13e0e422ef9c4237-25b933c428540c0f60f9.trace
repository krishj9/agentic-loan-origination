0.1);\n}\n\n/* ============================================\n   Base Styles\n   ============================================ */\n*,\n*::before,\n*::after {\n  box-sizing: border-box;\n}\n\nbody {\n  margin: 0;\n  font-family: var(--font-family);\n  font-size: var(--font-size-base);\n  line-height: 1.5;\n  color: var(--color-text);\n  background-color: var(--color-bg-alt);\n  -webkit-font-smoothing: antialiased;\n  -moz-osx-font-smoothing: grayscale;\n}\n\nh1, h2, h3, h4, h5, h6 {\n  margin-top: 0;\n  margin-bottom: var(--spacing-md);\n  font-weight: 600;\n  line-height: 1.2;\n}\n\nh1 { font-size: var(--font-size-3xl); }\nh2 { font-size: var(--font-size-2xl); }\nh3 { font-size: var(--font-size-xl); }\nh4 { font-size: var(--font-size-lg); }\n\np {\n  margin-top: 0;\n  margin-bottom: var(--spacing-md);\n}\n\na {\n  color: var(--color-primary);\n  text-decoration: none;\n}\n\na:hover {\n  text-decoration: underline;\n}\n\nul, ol {\n  margin-top: 0;\n  margin-bottom: var(--spacing-md);\n  padding-left: var(--spacing-lg);\n}\n\ncode {\n  font-family: 'Courier New', monospace;\n  font-size: 0.9em;\n  background-color: var(--color-bg-alt);\n  padding: 0.125rem 0.25rem;\n  border-radius: var(--radius-sm);\n}\n\n.sr-only {\n  position: absolute;\n  width: 1px;\n  height: 1px;\n  padding: 0;\n  margin: -1px;\n  overflow: hidden;\n  clip: rect(0, 0, 0, 0);\n  white-space: nowrap;\n  border-width: 0;\n}\n\n/* ============================================\n   Layout\n   ============================================ */\n.layout {\n  min-height: 100vh;\n  display: flex;\n  flex-direction: column;\n}\n\n.layout__header {\n  background-color: var(--color-bg);\n  border-bottom: 1px solid var(--color-border);\n  padding: var(--spacing-md) 0;\n}\n\n.layout__container {\n  max-width: 1200px;\n  margin: 0 auto;\n  padding: 0 var(--spacing-lg);\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  gap: var(--spacing-lg);\n}\n\n.layout__brand {\n  flex-shrink: 0;\n}\n\n.layout__logo {\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  color: var(--color-text);\n  text-decoration: none;\n}\n\n.layout__nav-list {\n  display: flex;\n  gap: var(--spacing-lg);\n  list-style: none;\n  margin: 0;\n  padding: 0;\n}\n\n.layout__nav-link {\n  color: var(--color-text);\n  font-weight: 500;\n  padding: var(--spacing-sm) var(--spacing-md);\n  border-radius: var(--radius-md);\n  transition: background-color 0.2s;\n}\n\n.layout__nav-link:hover {\n  background-color: var(--color-bg-alt);\n  text-decoration: none;\n}\n\n.layout__user {\n  display: flex;\n  align-items: center;\n  gap: var(--spacing-md);\n}\n\n.layout__username {\n  font-size: var(--font-size-sm);\n  color: var(--color-text-secondary);\n}\n\n.layout__main {\n  flex: 1;\n  padding: var(--spacing-2xl) 0;\n}\n\n.layout__footer {\n  background-color: var(--color-bg);\n  border-top: 1px solid var(--color-border);\n  padding: var(--spacing-lg) 0;\n  text-align: center;\n  color: var(--color-text-secondary);\n  font-size: var(--font-size-sm);\n}\n\n/* ============================================\n   Button Component\n   ============================================ */\n.btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n  gap: var(--spacing-sm);\n  padding: var(--spacing-sm) var(--spacing-lg);\n  font-size: var(--font-size-base);\n  font-weight: 500;\n  line-height: 1.5;\n  text-align: center;\n  border: 1px solid transparent;\n  border-radius: var(--radius-md);\n  cursor: pointer;\n  transition: all 0.2s;\n  white-space: nowrap;\n}\n\n.btn:disabled {\n  opacity: 0.5;\n  cursor: not-allowed;\n}\n\n.btn--primary {\n  background-color: var(--color-primary);\n  color: white;\n}\n\n.btn--primary:hover:not(:disabled) {\n  background-color: var(--color-primary-hover);\n}\n\n.btn--secondary {\n  background-color: var(--color-secondary);\n  color: white;\n}\n\n.btn--secondary:hover:not(:disabled) {\n  background-color: var(--color-secondary-hover);\n}\n\n.btn--danger {\n  background-color: var(--color-danger);\n  color: white;\n}\n\n.btn--danger:hover:not(:disabled) {\n  background-color: var(--color-danger-hover);\n}\n\n.btn--sm {\n  padding: var(--spacing-xs) var(--spacing-md);\n  font-size: var(--font-size-sm);\n}\n\n.btn--lg {\n  padding: var(--spacing-md) var(--spacing-xl);\n  font-size: var(--font-size-lg);\n}\n\n.btn--full-width {\n  width: 100%;\n}\n\n/* ============================================\n   Card Component\n   ============================================ */\n.card {\n  background-color: var(--color-bg);\n  border: 1px solid var(--color-border);\n  border-radius: var(--radius-lg);\n  box-shadow: var(--shadow-sm);\n  margin-bottom: var(--spacing-lg);\n}\n\n.card__header {\n  padding: var(--spacing-lg);\n  border-bottom: 1px solid var(--color-border);\n}\n\n.card__title {\n  margin: 0;\n  font-size: var(--font-size-xl);\n}\n\n.card__content {\n  padding: var(--spacing-lg);\n}\n\n/* ============================================\n   Input Component\n   ============================================ */\n.input-field {\n  margin-bottom: var(--spacing-lg);\n}\n\n.input-field__label {\n  display: block;\n  font-weight: 500;\n  margin-bottom: var(--spacing-sm);\n  color: var(--color-text);\n}\n\n.input-field__required {\n  color: var(--color-danger);\n  margin-left: var(--spacing-xs);\n}\n\n.input-field__input {\n  display: block;\n  width: 100%;\n  padding: var(--spacing-sm) var(--spacing-md);\n  font-size: var(--font-size-base);\n  line-height: 1.5;\n  color: var(--color-text);\n  background-color: var(--color-bg);\n  border: 1px solid var(--color-border);\n  border-radius: var(--radius-md);\n  transition: border-color 0.2s;\n}\n\n.input-field__input:focus {\n  outline: none;\n  border-color: var(--color-primary);\n  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);\n}\n\n.input-field__input--error {\n  border-color: var(--color-danger);\n}\n\n.input-field__input--error:focus {\n  box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);\n}\n\n.input-field__helper {\n  display: block;\n  margin-top: var(--spacing-xs);\n  font-size: var(--font-size-sm);\n  color: var(--color-text-secondary);\n}\n\n.input-field__error {\n  display: block;\n  margin-top: var(--spacing-xs);\n  font-size: var(--font-size-sm);\n  color: var(--color-danger);\n}\n\n/* ============================================\n   Loading Spinner\n   ============================================ */\n.loading-spinner {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: var(--spacing-md);\n  padding: var(--spacing-xl);\n}\n\n.spinner {\n  border: 3px solid var(--color-border);\n  border-top-color: var(--color-primary);\n  border-radius: 50%;\n  animation: spin 0.8s linear infinite;\n}\n\n.spinner--sm {\n  width: 1rem;\n  height: 1rem;\n  border-width: 2px;\n}\n\n.spinner--md {\n  width: 2rem;\n  height: 2rem;\n}\n\n.spinner--lg {\n  width: 3rem;\n  height: 3rem;\n}\n\n@keyframes spin {\n  to { transform: rotate(360deg); }\n}\n\n.loading-spinner__label {\n  font-size: var(--font-size-base);\n  color: var(--color-text-secondary);\n}\n\n/* ============================================\n   Error Message\n   ============================================ */\n.error-message {\n  background-color: #fee2e2;\n  border: 1px solid #fca5a5;\n  border-radius: var(--radius-md);\n  padding: var(--spacing-lg);\n  margin-bottom: var(--spacing-lg);\n}\n\n.error-message__title {\n  margin: 0 0 var(--spacing-sm) 0;\n  color: var(--color-danger);\n  font-size: var(--font-size-lg);\n}\n\n.error-message__text {\n  margin: 0 0 var(--spacing-sm) 0;\n  color: #991b1b;\n}\n\n.error-message__status {\n  margin: 0;\n  font-size: var(--font-size-sm);\n  color: var(--color-text-secondary);\n}\n\n/* ============================================\n   Empty State\n   ============================================ */\n.empty-state {\n  text-align: center;\n  padding: var(--spacing-2xl);\n  color: var(--color-text-secondary);\n}\n\n.empty-state__icon {\n  font-size: 3rem;\n  margin-bottom: var(--spacing-md);\n}\n\n.empty-state__title {\n  margin-bottom: var(--spacing-sm);\n  color: var(--color-text);\n}\n\n.empty-state__description {\n  margin-bottom: var(--spacing-lg);\n}\n\n/* ============================================\n   Error Boundary\n   ============================================ */\n.error-boundary {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  min-height: 100vh;\n  padding: var(--spacing-xl);\n}\n\n.error-boundary__content {\n  text-align: center;\n  max-width: 500px;\n}\n\n/* ============================================\n   Application Form\n   ============================================ */\n.application-form {\n  max-width: 600px;\n}\n\n.application-form__actions {\n  margin-top: var(--spacing-xl);\n}\n\n/* ============================================\n   Document Upload\n   ============================================ */\n.document-upload__instructions {\n  margin-bottom: var(--spacing-md);\n}\n\n.document-upload__requirements {\n  margin-bottom: var(--spacing-lg);\n}\n\n.document-upload__dropzone {\n  border: 2px dashed var(--color-border);\n  border-radius: var(--radius-lg);\n  padding: var(--spacing-2xl);\n  text-align: center;\n  transition: all 0.2s;\n  cursor: pointer;\n  background-color: var(--color-bg-alt);\n  margin-bottom: var(--spacing-lg);\n}\n\n.document-upload__dropzone:hover {\n  border-color: var(--color-primary);\n  background-color: #eff6ff;\n}\n\n.document-upload__dropzone--active {\n  border-color: var(--color-primary);\n  background-color: #eff6ff;\n}\n\n.document-upload__input {\n  display: none;\n}\n\n.document-upload__label {\n  cursor: pointer;\n}\n\n.document-upload__hint {\n  font-size: var(--font-size-sm);\n  color: var(--color-text-secondary);\n  margin-top: var(--spacing-sm);\n}\n\n.document-upload__files {\n  margin-bottom: var(--spacing-lg);\n}\n\n.document-upload__file-list {\n  list-style: none;\n  padding: 0;\n  margin: var(--spacing-md) 0;\n}\n\n.document-upload__file-item {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: var(--spacing-md);\n  border: 1px solid var(--color-border);\n  border-radius: var(--radius-md);\n  margin-bottom: var(--spacing-sm);\n}\n\n.document-upload__file-info {\n  flex: 1;\n}\n\n.document-upload__file-name {\n  display: block;\n  font-weight: 500;\n}\n\n.document-upload__file-type {\n  display: block;\n  font-size: var(--font-size-sm);\n  color: var(--color-text-secondary);\n}\n\n.status-success {\n  color: var(--color-success);\n  font-weight: 500;\n}\n\n.status-error {\n  color: var(--color-danger);\n  font-weight: 500;\n}\n\n/* ============================================\n   Application Status\n   ============================================ */\n.application-status {\n  max-width: 600px;\n}\n\n.application-status__current {\n  text-align: center;\n  margin-bottom: var(--spacing-xl);\n}\n\n.application-status__id {\n  font-size: var(--font-size-sm);\n  color: var(--color-text-secondary);\n  margin-top: var(--spacing-sm);\n}\n\n.application-status__details dl {\n  display: grid;\n  grid-template-columns: auto 1fr;\n  gap: var(--spacing-sm) var(--spacing-lg);\n  margin: var(--spacing-lg) 0;\n}\n\n.application-status__details dt {\n  font-weight: 500;\n}\n\n.application-status__details dd {\n  margin: 0;\n}\n\n.application-status__progress {\n  text-align: center;\n  margin: var(--spacing-xl) 0;\n}\n\n.application-status__message {\n  color: var(--color-text-secondary);\n  margin-top: var(--spacing-md);\n}\n\n.status-badge {\n  display: inline-block;\n  padding: var(--spacing-xs) var(--spacing-md);\n  font-size: var(--font-size-sm);\n  font-weight: 600;\n  border-radius: var(--radius-md);\n  text-transform: uppercase;\n}\n\n.status-badge--pending {\n  background-color: #fef3c7;\n  color: #92400e;\n}\n\n.status-badge--processing {\n  background-color: #dbeafe;\n  color: #1e40af;\n}\n\n.status-badge--completed {\n  background-color: #d1fae5;\n  color: #065f46;\n}\n\n.status-badge--failed {\n  background-color: #fee2e2;\n  color: #991b1b;\n}\n\n.status-badge--review {\n  background-color: #e0e7ff;\n  color: #3730a3;\n}\n\n/* ============================================\n   Decision View\n   ============================================ */\n.decision-view {\n  max-width: 800px;\n}\n\n.decision-view__outcome {\n  text-align: center;\n  padding: var(--spacing-xl);\n  border-radius: var(--radius-lg);\n  margin-bottom: var(--spacing-xl);\n}\n\n.decision-view__outcome--approve {\n  background-color: #d1fae5;\n  color: #065f46;\n}\n\n.decision-view__outcome--refer {\n  background-color: #fef3c7;\n  color: #92400e;\n}\n\n.decision-view__outcome--decline {\n  background-color: #fee2e2;\n  color: #991b1b;\n}\n\n.decision-view__outcome-title {\n  margin: var(--spacing-sm) 0 0 0;\n}\n\n.outcome-badge {\n  display: inline-flex;\n  align-items: center;\n  gap: var(--spacing-sm);\n  padding: var(--spacing-sm) var(--spacing-lg);\n  font-size: var(--font-size-xl);\n  font-weight: 600;\n  border-radius: var(--radius-lg);\n}\n\n.outcome-badge--approve {\n  background-color: var(--color-success);\n  color: white;\n}\n\n.outcome-badge--refer {\n  background-color: var(--color-warning);\n  color: white;\n}\n\n.outcome-badge--decline {\n  background-color: var(--color-danger);\n  color: white;\n}\n\n.decision-view__risk {\n  display: flex;\n  gap: var(--spacing-xl);\n  margin-bottom: var(--spacing-xl);\n  justify-content: center;\n}\n\n.decision-view__risk-item {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  gap: var(--spacing-sm);\n}\n\n.decision-view__label {\n  font-weight: 500;\n  color: var(--color-text-secondary);\n}\n\n.decision-view__value {\n  font-size: var(--font-size-2xl);\n  font-weight: 600;\n}\n\n.risk-profile-badge {\n  padding: var(--spacing-sm) var(--spacing-lg);\n  font-size: var(--font-size-lg);\n  font-weight: 600;\n  border-radius: var(--radius-md);\n}\n\n.risk-profile-badge--prime {\n  background-color: #d1fae5;\n  color: #065f46;\n}\n\n.risk-profile-badge--near_prime {\n  background-color: #fef3c7;\n  color: #92400e;\n}\n\n.risk-profile-badge--subprime {\n  background-color: #fee2e2;\n  color: #991b1b;\n}\n\n.decision-view__rationale {\n  background-color: var(--color-bg-alt);\n  padding: var(--spacing-lg);\n  border-radius: var(--radius-md);\n  margin-bottom: var(--spacing-xl);\n}\n\n.decision-view__section {\n  margin-bottom: var(--spacing-xl);\n  padding-bottom: var(--spacing-xl);\n  border-bottom: 1px solid var(--color-border);\n}\n\n.decision-view__section:last-child {\n  border-bottom: none;\n}\n\n.decision-view__details dl {\n  display: grid;\n  grid-template-columns: auto 1fr;\n  gap: var(--spacing-sm) var(--spacing-lg);\n}\n\n.decision-view__details dt {\n  font-weight: 500;\n}\n\n.decision-view__details dd {\n  margin: 0;\n}\n\n.decision-view__flags {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n}\n\n.decision-view__flag {\n  display: inline-block;\n  padding: var(--spacing-xs) var(--spacing-sm);\n  margin-right: var(--spacing-sm);\n  margin-bottom: var(--spacing-sm);\n  background-color: #fee2e2;\n  color: #991b1b;\n  border-radius: var(--radius-sm);\n  font-size: var(--font-size-sm);\n  font-weight: 500;\n}\n\n.decision-view__compliance-flags {\n  list-style: none;\n  padding: 0;\n  margin: var(--spacing-md) 0;\n}\n\n.compliance-flag {\n  padding: var(--spacing-md);\n  margin-bottom: var(--spacing-sm);\n  border-radius: var(--radius-md);\n  border-left: 4px solid;\n}\n\n.compliance-flag--low {\n  background-color: #f0fdf4;\n  border-color: var(--color-success);\n}\n\n.compliance-flag--medium {\n  background-color: #fef3c7;\n  border-color: var(--color-warning);\n}\n\n.compliance-flag--high {\n  background-color: #fee2e2;\n  border-color: var(--color-danger);\n}\n\n.compliance-flag--critical {\n  background-color: #fee2e2;\n  border-color: #7f1d1d;\n}\n\n.decision-view__artifacts {\n  margin: var(--spacing-xl) 0;\n}\n\n.decision-view__artifact-buttons {\n  display: flex;\n  gap: var(--spacing-md);\n  margin-top: var(--spacing-md);\n}\n\n.decision-view__audit {\n  margin-top: var(--spacing-xl);\n  padding-top: var(--spacing-xl);\n  border-top: 1px solid var(--color-border);\n}\n\n.decision-view__audit summary {\n  cursor: pointer;\n  font-weight: 500;\n  color: var(--color-text-secondary);\n}\n\n.decision-view__audit dl {\n  display: grid;\n  grid-template-columns: auto 1fr;\n  gap: var(--spacing-sm) var(--spacing-lg);\n  margin-top: var(--spacing-md);\n}\n\n.decision-view__audit dt {\n  font-weight: 500;\n  color: var(--color-text-secondary);\n}\n\n.decision-view__audit dd {\n  margin: 0;\n  font-family: monospace;\n  font-size: var(--font-size-sm);\n}\n\n/* ============================================\n   Home Page\n   ============================================ */\n.home-page__hero {\n  text-align: center;\n  margin-bottom: var(--spacing-2xl);\n}\n\n.home-page__cards {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));\n  gap: var(--spacing-lg);\n  margin-bottom: var(--spacing-2xl);\n}\n\n.home-page__info {\n  background-color: var(--color-bg);\n  padding: var(--spacing-xl);\n  border-radius: var(--radius-lg);\n  border: 1px solid var(--color-border);\n}\n\n/* ============================================\n   Login Page\n   ============================================ */\n.login-page {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  min-height: 80vh;\n}\n\n.login-page__content {\n  max-width: 400px;\n}\n\n.login-page__message {\n  margin-bottom: var(--spacing-lg);\n  color: var(--color-text-secondary);\n}\n\n/* ============================================\n   Admin Page\n   ============================================ */\n.admin-page__links {\n  list-style: none;\n  padding: 0;\n}\n\n.admin-page__links li {\n  margin-bottom: var(--spacing-sm);\n}\n\n.admin-page__config {\n  display: grid;\n  grid-template-columns: auto 1fr;\n  gap: var(--spacing-sm) var(--spacing-lg);\n}\n\n.admin-page__config dt {\n  font-weight: 500;\n}\n\n.admin-page__config dd {\n  margin: 0;\n}\n\n/* ============================================\n   Protected Route\n   ============================================ */\n.protected-route__loading {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  min-height: 80vh;\n}\n\n.protected-route__forbidden {\n  text-align: center;\n  padding: var(--spacing-2xl);\n}\n\n/* ============================================\n   Responsive Design\n   ============================================ */\n@media (max-width: 768px) {\n  .layout__container {\n    flex-direction: column;\n    align-items: flex-start;\n  }\n\n  .layout__nav {\n    width: 100%;\n  }\n\n  .layout__nav-list {\n    flex-direction: column;\n    gap: var(--spacing-sm);\n  }\n\n  .layout__user {\n    width: 100%;\n    justify-content: space-between;\n  }\n\n  .decision-view__risk {\n    flex-direction: column;\n  }\n\n  .decision-view__artifact-buttons {\n    flex-direction: column;\n  }\n\n  .home-page__cards {\n    grid-template-columns: 1fr;\n  }\n}\n"]],"\n  ",["BODY",{},"\n    ",["DIV",{"id":"root"}],"\n    ","\n  \n\n"]],"viewport":{"width":1280,"height":720},"timestamp":34701.529,"wallTime":1782244440130,"collectionTime":0.5,"resourceOverrides":[],"isMainFrame":true}}
