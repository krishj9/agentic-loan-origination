# ── Frontend environment variables ───────────────────────────────────────
# Copy this file to .env.local and populate for local development.
# NEVER commit .env.local to source control.

# Base URL for the FastAPI backend (no trailing slash).
# Defaults to the Vite dev proxy (/api → http://localhost:8000).
VITE_API_BASE_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# AWS Configuration
VITE_AWS_REGION=us-east-1

# Amazon Cognito configuration (output by terraform apply).
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_OAUTH_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com
VITE_COGNITO_REDIRECT_SIGN_IN=http://localhost:5173
VITE_COGNITO_REDIRECT_SIGN_OUT=http://localhost:5173

# Monitoring (optional)
VITE_CLOUDWATCH_LOGS_URL=https://console.aws.amazon.com/cloudwatch
