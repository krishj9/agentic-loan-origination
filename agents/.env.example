# ── Agents environment variables ─────────────────────────────────────────
# Copy this file to .env and populate before running the agent layer.
# NEVER commit .env to source control.

# ── AWS ───────────────────────────────────────────────────────────────────
AWS_PROFILE=loan-origination-dev
AWS_REGION=us-east-1

# ── Amazon Bedrock ────────────────────────────────────────────────────────
# Model ID used for LLM-bearing supervisor nodes.
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_GUARDRAIL_ID=xxxxxxxxxxxxxxxx
BEDROCK_GUARDRAIL_VERSION=1

# ── AgentCore ────────────────────────────────────────────────────────────
AGENTCORE_RUNTIME_ARN=arn:aws:bedrock:us-east-1:123456789012:agent-runtime/XXXXXXXXXX
AGENTCORE_GATEWAY_ARN=arn:aws:bedrock:us-east-1:123456789012:agent-gateway/XXXXXXXXXX

# ── LlamaParse / Llama Cloud ─────────────────────────────────────────────
# Obtained from https://cloud.llamaindex.ai/api-key
LLAMA_CLOUD_API_KEY=llx-...
LLAMA_CLOUD_BASE_URL=https://api.cloud.llamaindex.ai

# ── S3 ────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=loan-origination-documents-demo
# S3_ENDPOINT_URL=http://localhost:4566

# ── Runtime mode ─────────────────────────────────────────────────────────
# "local" runs the LangGraph supervisor in-process (no AgentCore Runtime).
# "agentcore" routes sessions through AgentCore Runtime.
RUNTIME_MODE=local
LOG_LEVEL=INFO
